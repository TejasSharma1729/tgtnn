{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/assets/Eigen",
                "${workspaceFolder}/assets",
                "/usr/include",
                "/usr/local/include"
            ],
            "defines": [
                "NUM_THREADS=16"
            ],
            "compilerPath": "/usr/bin/g++",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-x64",
            "compilerArgs": [
                "-std=c++17"
            ]
        }
    ],
    "version": 4
}
