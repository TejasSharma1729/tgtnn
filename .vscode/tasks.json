{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C++ compile",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-I${workspaceFolder}/assets/Eigen",
                "-I${workspaceFolder}/assets",
                "-c",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.o"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "Compile current C++ file"
        }
    ]
}
